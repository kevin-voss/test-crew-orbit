{
  "name": "simple-bun-react-app",
  "version": "1.0.0",
  "description": "A simple React app built with Bun",
  "main": "index.tsx",
  "scripts": {
    "dev": "bun run index.tsx",
    "build": "bun build ./index.tsx --outfile ./dist/index.js",
    "start": "bun run build && bun run dist/index.js"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  }
}
